{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "ForensicReplayResponseV1",
  "type": "object",
  "additionalProperties": false,
  "required": ["turn_id", "event_timeline", "tool_executions"],
  "properties": {
    "turn_id": { "type": "string", "format": "uuid" },
    "ingress": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "channel": { "type": "string" },
        "message": { "type": "string" },
        "created_at": { "type": "string", "format": "date-time" }
      }
    },
    "event_timeline": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["event", "timestamp"],
        "properties": {
          "event": { "type": "string" },
          "timestamp": { "type": "string", "format": "date-time" },
          "attrs": { "type": "object", "additionalProperties": true }
        }
      }
    },
    "tool_executions": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["tool_key", "phase", "status"],
        "properties": {
          "tool_key": { "type": "string" },
          "phase": { "type": "string" },
          "status": { "type": "string" },
          "idempotency_key": { "type": "string" }
        }
      }
    },
    "final_response": { "type": "string" }
  }
}
