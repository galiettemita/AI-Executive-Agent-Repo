{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "MemoryWriteGateInput",
  "description": "Input document for memory_write_gate.rego policy evaluation.",
  "type": "object",
  "required": ["workspace_id", "user_id", "memory_type", "allowed_processors", "workspace_tier"],
  "properties": {
    "workspace_id": { "type": "string" },
    "user_id": { "type": "string" },
    "memory_type": {
      "type": "string",
      "enum": ["episodic", "semantic", "procedural", "rule", "preference", "daily_log", "heartbeat", "fact", "contact_fact", "task_fact"]
    },
    "data_class": {
      "type": "string",
      "enum": ["public", "internal", "confidential", "restricted", ""],
      "default": "internal"
    },
    "sensitivity_label": {
      "type": "string",
      "enum": ["none", "low", "moderate", "high", "regulated", "standard", "sensitive", ""],
      "default": "standard"
    },
    "retention_policy_id": { "type": "string" },
    "allowed_processors": {
      "type": "array",
      "items": { "type": "string" }
    },
    "workspace_tier": {
      "type": "string",
      "enum": ["free", "pro", "business", "enterprise"]
    },
    "memory_write_blocked": { "type": "boolean", "default": false },
    "content_byte_size": { "type": "integer", "minimum": 0 },
    "ttl_override_days": { "type": "number", "minimum": 0 }
  }
}
