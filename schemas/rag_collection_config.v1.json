{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "collection_id": {
      "type": "string",
      "minLength": 1
    },
    "workspace_id": {
      "type": "string",
      "minLength": 1
    },
    "name": {
      "type": "string",
      "minLength": 1,
      "maxLength": 200
    },
    "embedding_model": {
      "type": "string",
      "minLength": 1
    },
    "chunk_size": {
      "type": "integer",
      "minimum": 64
    },
    "bm25_enabled": {
      "type": "boolean"
    }
  },
  "required": [
    "collection_id",
    "workspace_id",
    "name",
    "embedding_model",
    "chunk_size",
    "bm25_enabled"
  ]
}
