{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "WhatsAppWebhookPayloadV1",
  "type": "object",
  "additionalProperties": false,
  "required": ["object", "entry"],
  "properties": {
    "object": { "type": "string" },
    "entry": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["id", "changes"],
        "properties": {
          "id": { "type": "string" },
          "changes": {
            "type": "array",
            "items": {
              "type": "object",
              "additionalProperties": false,
              "required": ["value"],
              "properties": {
                "field": { "type": "string" },
                "value": {
                  "type": "object",
                  "additionalProperties": false,
                  "required": ["messaging_product", "metadata"],
                  "properties": {
                    "messaging_product": { "type": "string" },
                    "metadata": {
                      "type": "object",
                      "additionalProperties": false,
                      "required": ["phone_number_id"],
                      "properties": {
                        "display_phone_number": { "type": "string" },
                        "phone_number_id": { "type": "string" }
                      }
                    },
                    "messages": {
                      "type": "array",
                      "items": {
                        "type": "object",
                        "additionalProperties": true
                      }
                    },
                    "statuses": {
                      "type": "array",
                      "items": {
                        "type": "object",
                        "additionalProperties": true
                      }
                    }
                  }
                }
              }
            }
          }
        }
      }
    }
  }
}
