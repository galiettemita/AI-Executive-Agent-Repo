{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "event_id": {
      "type": "string",
      "minLength": 1
    },
    "rule_key": {
      "type": "string",
      "minLength": 1
    },
    "event_type": {
      "type": "string",
      "minLength": 1
    },
    "severity": {
      "type": "string",
      "minLength": 1
    },
    "blocked": {
      "type": "boolean"
    },
    "reason": {
      "type": "string",
      "maxLength": 1000
    }
  },
  "required": [
    "event_id",
    "rule_key",
    "event_type",
    "severity",
    "blocked",
    "reason"
  ]
}
