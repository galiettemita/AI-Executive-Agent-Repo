{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "intent": {
      "type": "string",
      "minLength": 1
    },
    "actions": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "properties": {
          "tool": {
            "type": "string",
            "pattern": "^[a-z0-9_]+\\.[a-z0-9_]+$"
          },
          "operation": {
            "type": "string",
            "minLength": 1
          },
          "params": {
            "type": "object"
          },
          "idempotency_key": {
            "type": "string",
            "minLength": 16,
            "maxLength": 128
          }
        },
        "required": [
          "tool",
          "operation",
          "params",
          "idempotency_key"
        ]
      }
    },
    "risk": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "impact": {
          "type": "string",
          "minLength": 1
        },
        "rollback_plan": {
          "type": "string",
          "minLength": 1
        }
      },
      "required": [
        "impact",
        "rollback_plan"
      ]
    },
    "requires_approval": {
      "type": "boolean"
    }
  },
  "required": [
    "intent",
    "actions",
    "risk",
    "requires_approval"
  ]
}
