{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "ProvisioningBudgetResponseV1",
  "type": "object",
  "additionalProperties": false,
  "required": ["workspace_id", "max_monthly_llm_cost", "max_monthly_api_calls", "max_concurrent_mcp_servers", "max_single_transaction", "updated_at"],
  "properties": {
    "workspace_id": { "type": "string", "format": "uuid" },
    "max_monthly_llm_cost": { "type": "number", "minimum": 0 },
    "max_monthly_api_calls": { "type": "integer", "minimum": 0 },
    "max_concurrent_mcp_servers": { "type": "integer", "minimum": 0 },
    "max_single_transaction": { "type": "number", "minimum": 0 },
    "updated_at": { "type": "string", "format": "date-time" }
  }
}
