{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "PlanEvaluateRequestV1",
  "type": "object",
  "additionalProperties": false,
  "required": ["workspace_id", "plan_id", "plan_tier", "tool_calls"],
  "properties": {
    "workspace_id": { "type": "string", "format": "uuid" },
    "plan_id": { "type": "string" },
    "plan_tier": { "type": "string" },
    "tool_calls": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["tool_key", "is_write", "risk_level"],
        "properties": {
          "tool_key": { "type": "string" },
          "is_write": { "type": "boolean" },
          "risk_level": { "type": "string" },
          "estimated_cost": { "type": "number", "minimum": 0 },
          "estimated_latency_ms": { "type": "integer", "minimum": 0 },
          "capability_binding_strength": { "type": "integer", "minimum": 0, "maximum": 100 }
        }
      }
    }
  }
}
