{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "workspace_id": {
      "type": "string",
      "minLength": 1
    },
    "collection_id": {
      "type": "string",
      "minLength": 1
    },
    "query": {
      "type": "string",
      "minLength": 1,
      "maxLength": 4000
    },
    "top_k": {
      "type": "integer",
      "minimum": 1,
      "maximum": 50
    },
    "include_provenance": {
      "type": "boolean"
    }
  },
  "required": [
    "workspace_id",
    "collection_id",
    "query",
    "top_k",
    "include_provenance"
  ]
}
