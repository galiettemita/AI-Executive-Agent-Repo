# ==============================================================================
# BREVIO — ENVIRONMENT VARIABLE TEMPLATE
# Copy to .env and fill in values. Do NOT commit .env to version control.
# 43 variables required for full system operation.
# ==============================================================================

# ── LLM / Voice ────────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
DEEPGRAM_API_KEY=
CARTESIA_API_KEY=
VAPI_API_KEY=
RETELL_API_KEY=
COHERE_API_KEY=

# ── MCP / Hands Runtime ─────────────────────────────────────────────────────────
MCP_BASE_URL=http://hands-runtime:18089/mcp
HANDS_RUNTIME_URL=
CONNECTORS_MASTER_KEY_B64=
CONNECTORS_SEED_FILE=seeds/connectors.json

# ── Browser MCP ─────────────────────────────────────────────────────────────────
BROWSER_MCP_URL=
BROWSER_MCP_HMAC_KEY=

# ── OAuth ───────────────────────────────────────────────────────────────────────
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
MICROSOFT_CLIENT_ID=
MICROSOFT_CLIENT_SECRET=

# ── Search & Web ────────────────────────────────────────────────────────────────
BRAVE_SEARCH_API_KEY=
PERPLEXITY_API_KEY=
EXA_API_KEY=
FIRECRAWL_API_KEY=
TAVILY_API_KEY=

# ── Productivity / SaaS ─────────────────────────────────────────────────────────
SLACK_BOT_TOKEN=
NOTION_TOKEN=
LINEAR_API_KEY=
ASANA_ACCESS_TOKEN=
JIRA_API_TOKEN=
JIRA_BASE_URL=
JIRA_EMAIL=
GITHUB_TOKEN=

# ── Finance / Health / Home ──────────────────────────────────────────────────────
PLAID_CLIENT_ID=
PLAID_SECRET=
SPOTIFY_TOKEN=
DEXCOM_TOKEN=
WITHINGS_TOKEN=
HOME_ASSISTANT_URL=
HOME_ASSISTANT_TOKEN=

# ── DPO Fine-Tuning (OpenAI) ─────────────────────────────────────────────────────
OPENAI_FINETUNE_BASE_URL=https://api.openai.com/v1
DPO_BASE_MODEL=gpt-4o-mini-2024-07-18

# ── Additional APIs ──────────────────────────────────────────────────────────────
GOOGLE_PLACES_API_KEY=
SERPAPI_KEY=
FAL_KEY=

# ── Multi-Provider LLM Routing ──────────────────────────────────────────────────
GEMINI_API_KEY=           # Google Gemini API key
GROQ_API_KEY=             # Groq API key (800 tok/s, OpenAI-compat)
MISTRAL_API_KEY=          # Mistral AI key (EU data residency)
OLLAMA_BASE_URL=          # Optional. Leave empty to disable Ollama.
EU_DATA_RESIDENCY=false   # Set true to force Mistral for all requests
PRIVACY_MODE=             # Set "strict" to force Ollama local inference

# ── Google Vertex AI (Multimodal Embeddings) ─────────────────────────────────────
GOOGLE_CLOUD_PROJECT=             # GCP project ID
GOOGLE_APPLICATION_CREDENTIALS=   # Path to service account JSON key file

# ── Red Team (P3-01) ─────────────────────────────────────────────────────────────
INTERNAL_REDTEAM_KEY=             # API key for internal red-team safety evaluation.

# ── Watermarking & Provenance (P3-02) ────────────────────────────────────────────
OLLAMA_SHADOW_MODEL=llama3.2:3b   # Shadow model for membership inference audit.

# ── Fine-Tuning Providers (P3-10) ────────────────────────────────────────────────
ANTHROPIC_FINETUNE_ENABLED=false  # Enable Anthropic fine-tuning API.
ANTHROPIC_FINETUNE_API_KEY=       # Anthropic fine-tuning API key (optional, falls back to ANTHROPIC_API_KEY).

# ── Shadow Evaluation (P3-12) ────────────────────────────────────────────────────
SHADOW_EVAL_ENABLED=false         # Enable shadow evaluation for model comparison.
SHADOW_EVAL_RATE=0.05             # Application-level sampling rate (0.0-1.0).
CHAMPION_MODEL=claude-sonnet-4-5  # Current production champion model.
CHALLENGER_MODEL=                 # Model under evaluation.

# ── Alert Routing (P3-08) ────────────────────────────────────────────────────────
ALERT_PROVIDER=webhook            # pagerduty | opsgenie | slack | webhook
PAGERDUTY_ROUTING_KEY=            # Required when ALERT_PROVIDER=pagerduty.
OPSGENIE_API_KEY=                 # Required when ALERT_PROVIDER=opsgenie.
SLACK_WEBHOOK_URL=                # Required when ALERT_PROVIDER=slack.
ALERT_WEBHOOK_URL=                # Fallback webhook URL.

# ── Istio Service Mesh (P3-09) ───────────────────────────────────────────────────
ISTIO_MTLS_ENABLED=false          # Set true when Istio sidecar handles inter-service mTLS.
WATERMARK_HMAC_KEY=               # Required. 32-byte hex-encoded HMAC key for watermarks.
WATERMARK_ENABLED=true            # Enable C2PA content watermarking.
SEMANTIC_WATERMARK_ENABLED=true   # Enable semantic synonym watermarking.
