{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "retrieval_id": {
      "type": "string",
      "minLength": 1
    },
    "query_rewrite": {
      "type": "string"
    },
    "results": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "properties": {
          "chunk_id": {
            "type": "string",
            "minLength": 1
          },
          "score": {
            "type": "number"
          },
          "source": {
            "type": "string",
            "minLength": 1
          }
        },
        "required": [
          "chunk_id",
          "score",
          "source"
        ]
      }
    }
  },
  "required": [
    "retrieval_id",
    "query_rewrite",
    "results"
  ]
}
