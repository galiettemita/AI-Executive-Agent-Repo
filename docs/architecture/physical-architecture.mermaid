graph TB
    subgraph "AWS Cloud"
        subgraph "EKS Cluster (K8s 1.29)"
            subgraph "brevio-system namespace"
                GW_POD["Gateway Pods (3-20)"]
                BR_POD["Brain Pods (2-10)"]
                EX_POD["Executor Pods (3-15)"]
                CTL_POD["Control Pods"]
                CV_POD["Canvas Pods"]
                TW_POD["Temporal Worker Pods (2-8)"]
                BRW_POD["Browser Pods (2-8)"]
                MKT_POD["Marketing Pods (2-6)"]
                AG_POD["Agents Pods (2-10)"]
                MEM_POD["Memory Pods (2-6)"]
                RT_POD["Router Pods (2-6)"]
                CRN_POD["Cron Pods (1-3)"]
                AUTH_POD["Auth Pods (2-6)"]
                PROF_POD["Profile Pods (2-6)"]
                SCHED_POD["Scheduler Pods (1-2)"]
            end
        end

        subgraph "Managed Services"
            RDS["RDS PostgreSQL 16\n(pgvector, Multi-AZ)"]
            EC["ElastiCache Redis 7"]
            TEMP["Temporal Server"]
            SM["Secrets Manager\n(LLM API Keys)"]
            S3["S3\n(Files, Screenshots)"]
            SQS["SQS\n(Async Queues)"]
        end

        ALB["Application Load Balancer"]
        R53["Route 53 DNS"]
    end

    subgraph "External Services"
        LLM["LLM Providers\n(Anthropic, OpenAI, Google)"]
        CAPTCHA["Captcha Services\n(2captcha, anticaptcha)"]
        EMAIL["Email Providers\n(SendGrid, SES)"]
        SOCIAL["Social APIs\n(Twitter, LinkedIn)"]
        ENRICH["Enrichment APIs\n(Clearbit, Apollo)"]
    end

    R53 --> ALB
    ALB --> GW_POD
    GW_POD --> BR_POD
    BR_POD --> RT_POD
    RT_POD --> LLM
    BR_POD --> AG_POD
    BR_POD --> MEM_POD
    BR_POD --> EX_POD
    BR_POD --> BRW_POD
    BR_POD --> MKT_POD
    CRN_POD --> TW_POD
    TW_POD --> TEMP
    BRW_POD --> CAPTCHA
    MKT_POD --> EMAIL
    MKT_POD --> SOCIAL
    MKT_POD --> ENRICH

    GW_POD --> RDS
    BR_POD --> RDS
    EX_POD --> RDS
    BRW_POD --> RDS
    MKT_POD --> RDS
    AG_POD --> RDS
    MEM_POD --> RDS
    RT_POD --> RDS
    CRN_POD --> RDS

    GW_POD --> EC
    BR_POD --> EC
    EX_POD --> EC
    BRW_POD --> EC

    BR_POD --> SM
    RT_POD --> SM
    BRW_POD --> S3
