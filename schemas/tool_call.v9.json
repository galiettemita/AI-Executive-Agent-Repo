{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "tool_key": {
      "type": "string",
      "pattern": "^[a-z0-9_]+\\.[a-z0-9_]+$"
    },
    "tool_contract_version": {
      "type": "string",
      "const": "2026.tool-use.v2"
    },
    "request_id": {
      "type": "string",
      "minLength": 1
    },
    "run_id": {
      "type": "string",
      "minLength": 1
    },
    "thread_id": {
      "type": "string",
      "minLength": 1
    },
    "step_id": {
      "type": "string",
      "minLength": 1
    },
    "attempt": {
      "type": "integer",
      "minimum": 1
    },
    "idempotency_key": {
      "type": "string",
      "minLength": 16,
      "maxLength": 128
    },
    "arguments": {
      "type": "object"
    },
    "requested_risk": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "level": {
          "type": "string"
        },
        "reversible": {
          "type": "boolean"
        }
      },
      "required": [
        "level",
        "reversible"
      ]
    },
    "policy": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "consent_requirement": {
          "type": "string",
          "enum": ["none", "recommended", "required"]
        },
        "human_review": {
          "type": "string",
          "enum": ["none", "recommended", "required"]
        },
        "recipient_verification": {
          "type": "string",
          "enum": ["not_applicable", "required", "verified"]
        }
      }
    },
    "workspace_id": {
      "type": "string",
      "pattern": "^[0-9a-f]{8}-[0-9a-f]{4}-7[0-9a-f]{3}-[89ab][0-9a-f]{3}-[0-9a-f]{12}$"
    },
    "ingress_turn_id": {
      "type": "string",
      "pattern": "^[0-9a-f]{8}-[0-9a-f]{4}-7[0-9a-f]{3}-[89ab][0-9a-f]{3}-[0-9a-f]{12}$"
    }
  },
  "required": [
    "tool_key",
    "idempotency_key",
    "arguments",
    "requested_risk",
    "workspace_id",
    "ingress_turn_id"
  ]
}
