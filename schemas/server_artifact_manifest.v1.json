{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "image_digest": {
      "type": "string",
      "pattern": "^sha256:[a-f0-9]{64}$"
    },
    "sbom_s3_uri": {
      "type": "string",
      "pattern": "^s3://.+"
    },
    "vuln_scan_summary_json": {
      "type": "object"
    },
    "signature_bundle_json": {
      "type": "object"
    }
  },
  "required": [
    "image_digest",
    "sbom_s3_uri",
    "vuln_scan_summary_json",
    "signature_bundle_json"
  ]
}
