# Phase 3B.3 — Founder Real Gmail Smoke Test env template.
#
# HOW TO USE THIS FILE
# 1. Copy to apps/fomo/.env.3b3.local (the .local suffix is already
#    in .gitignore, so your real secrets won't be committed):
#
#        cp apps/fomo/.env.3b3.example apps/fomo/.env.3b3.local
#
# 2. Fill in each value below (replace the REPLACE_ME placeholders).
# 3. Source it into your shell BEFORE running the server or scripts:
#
#        set -a; source apps/fomo/.env.3b3.local; set +a
#        # OR (zsh / bash):
#        export $(grep -v '^#' apps/fomo/.env.3b3.local | xargs)
#
# 4. Run preflight, then build/start, then evidence — see
#    docs/smoke-test-3b3-gmail.md for the full procedure.
#
# DO NOT COMMIT apps/fomo/.env.3b3.local. The .gitignore covers
# .env.*.local; verify with `git check-ignore apps/fomo/.env.3b3.local`.

# ----------------------------------------------------------------------
# Persistence — Neon Postgres
# ----------------------------------------------------------------------
# Pooled connection string from https://console.neon.tech/.
# Example shape: postgres://USER:PASS@HOST/DB?sslmode=require
DATABASE_URL=REPLACE_ME_neon_pooled_connection_string

# ----------------------------------------------------------------------
# Crypto — three independent 32-byte keys.
# Generate each with: node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
# ----------------------------------------------------------------------
BREVIO_TOKEN_KEK=REPLACE_ME_base64_32_bytes
BREVIO_OAUTH_STATE_KEY=REPLACE_ME_base64_32_bytes
BREVIO_SESSION_SIGNING_KEY=REPLACE_ME_base64_32_bytes

# ----------------------------------------------------------------------
# Google OAuth — from Google Cloud Console OAuth 2.0 Client (Web app).
# Redirect URI must EXACTLY match what's configured in Google Cloud.
# For local dev:  http://localhost:8080/oauth/google/callback
# ----------------------------------------------------------------------
GOOGLE_CLIENT_ID=REPLACE_ME_xxxxxxxxxxxx.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=REPLACE_ME
BREVIO_OAUTH_REDIRECT_URI_GOOGLE=http://localhost:8080/oauth/google/callback

# ----------------------------------------------------------------------
# Phase 3B.3 polling — explicit opt-in, BOUNDED window.
# MAX_CYCLES caps the worker so it cannot keep polling against the
# live founder inbox if the founder forgets to stop the process.
# INTERVAL_MS optional; tighter than the 60_000 default makes the
# smoke test run faster.
# ----------------------------------------------------------------------
FOMO_GMAIL_POLLING_ENABLED=true
FOMO_GMAIL_POLLING_MAX_CYCLES=3
FOMO_GMAIL_POLLING_INTERVAL_MS=10000

# ----------------------------------------------------------------------
# Optional — only if not running on the default port.
# ----------------------------------------------------------------------
# PORT=8080

# ----------------------------------------------------------------------
# Forbidden during the 3B.3 smoke test. Leave these UNSET (or false).
# Preflight will fail loudly if any are 'true'.
# ----------------------------------------------------------------------
# FOMO_SEND_ENABLED=false
# FOMO_AUTO_SEND_ENABLED=false
# FOMO_FRIEND_BETA_ENABLED=false
# BREVIO_DEV_MODE=  # must be UNSET so production fail-closed checks fire
