{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "workspace_id": {
      "type": "string",
      "minLength": 1
    },
    "refresh_cadence_minutes": {
      "type": "integer",
      "minimum": 1,
      "maximum": 1440
    },
    "widgets": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "properties": {
          "widget_id": {
            "type": "string",
            "minLength": 1
          },
          "widget_type": {
            "type": "string",
            "minLength": 1
          },
          "position": {
            "type": "integer",
            "minimum": 0
          }
        },
        "required": [
          "widget_id",
          "widget_type",
          "position"
        ]
      }
    }
  },
  "required": [
    "workspace_id",
    "refresh_cadence_minutes",
    "widgets"
  ]
}
