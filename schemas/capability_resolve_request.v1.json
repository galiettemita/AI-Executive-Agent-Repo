{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "query_text": {
      "type": "string",
      "minLength": 1,
      "maxLength": 2000
    },
    "allow_llm_fallback": {
      "type": "boolean"
    },
    "max_candidates": {
      "type": "integer",
      "minimum": 1,
      "maximum": 20
    }
  },
  "required": [
    "query_text",
    "allow_llm_fallback",
    "max_candidates"
  ]
}
