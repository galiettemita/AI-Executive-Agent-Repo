ENV=dev
DATABASE_URL=postgresql+psycopg://user:pass@localhost:5432/executive_ai_agent
JWT_SECRET=change-me
PII_ENCRYPTION_KEY=change-me
PII_ENCRYPTION_KEYS=
ENFORCE_WEBHOOK_SIGNATURES=1
AUDIT_LOG_ENABLED=1
STATE_SIGNING_SECRET=change-me
OPENAI_API_KEY=
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
APP_BASE_URL=http://localhost:8000
VOICE_CALL_AUTO_EXECUTE_ON_APPROVAL=1
ENABLE_VOICE_CALLS=0
VOICE_RECORDING_RETENTION_DAYS=30

REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=
CELERY_RESULT_BACKEND=

STORAGE_BACKEND=local
LOCAL_STORAGE_PATH=./storage
S3_BUCKET=
S3_REGION=
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
S3_ENDPOINT_URL=

VECTOR_DB_BACKEND=
PGVECTOR_DSN=
TAVILY_API_KEY=
TAVILY_SEARCH_DEPTH=basic

EMAIL_PROVIDER=ses
FROM_EMAIL=
FROM_NAME=Executive OS
SES_REGION=us-east-1
SES_CONFIGURATION_SET=
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=

PROMETHEUS_ENABLED=0
METRICS_TOKEN=
SENTRY_DSN=
SENTRY_TRACES_SAMPLE_RATE=0.05
SENTRY_PROFILES_SAMPLE_RATE=0.0

OTEL_ENABLED=0
OTEL_SERVICE_NAME=executive-ai-agent
OTEL_EXPORTER_OTLP_ENDPOINT=
OTEL_EXPORTER_OTLP_HEADERS=
OTEL_EXPORTER_OTLP_TRACES_ENDPOINT=
OTEL_EXPORTER_OTLP_TRACES_HEADERS=
OTEL_EXPORTER_OTLP_METRICS_ENDPOINT=
OTEL_EXPORTER_OTLP_METRICS_HEADERS=
OTEL_METRICS_ENABLED=1

SEMANTIC_CACHE_ENABLED=1
SEMANTIC_CACHE_TTL_SECONDS=21600
SEMANTIC_CACHE_MIN_SIMILARITY=0.92
SEMANTIC_CACHE_MIN_QUERY_CHARS=16

POSTHOG_API_KEY=
POSTHOG_HOST=https://app.posthog.com

ALERTING_PROVIDER=
SLACK_ALERT_WEBHOOK_URL=
PAGERDUTY_ROUTING_KEY=
BETA_MODE=0
BETA_ALLOWED_USER_IDS=

# Smart Home
SMART_HOME_DEFAULT_PROVIDER=home_assistant
ENABLE_SMART_HOME=0
ENERGY_MONITOR_INTERVAL_MINUTES=15
PROACTIVE_RULE_POLL_MINUTES=5

# Messaging
ENABLE_MESSAGING=0

# Phone verification / onboarding
REQUIRE_PHONE_VERIFICATION=0
PHONE_VERIFICATION_CODE_LENGTH=6
PHONE_VERIFICATION_CODE_TTL_MINUTES=10
PHONE_VERIFICATION_MAX_ATTEMPTS=5
PHONE_VERIFICATION_RESEND_COOLDOWN_SECONDS=60
PHONE_VERIFICATION_ALLOW_DEV_CODE_ECHO=1

# Google OAuth
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=
TOKEN_ENCRYPTION_KEY=

# Microsoft OAuth
MS_CLIENT_ID=
MS_CLIENT_SECRET=
MS_REDIRECT_URI=
MS_TENANT_ID=common

# CalDAV credentials are stored per-user via /admin/caldav/connect
