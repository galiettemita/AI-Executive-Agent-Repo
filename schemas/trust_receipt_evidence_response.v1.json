{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "TrustReceiptEvidenceResponseV1",
  "type": "object",
  "additionalProperties": false,
  "required": ["trust_receipt_id", "evidence_items"],
  "properties": {
    "trust_receipt_id": { "type": "string", "format": "uuid" },
    "evidence_items": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["type", "content"],
        "properties": {
          "type": { "type": "string" },
          "content": { "type": "string" },
          "source_id": { "type": "string" },
          "confidence": { "type": "number", "minimum": 0, "maximum": 1 }
        }
      }
    }
  }
}
