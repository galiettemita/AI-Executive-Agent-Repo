{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "workspace_id": {
      "type": "string",
      "minLength": 1
    },
    "tool_key": {
      "type": "string",
      "pattern": "^[a-z0-9_]+\\.[a-z0-9_]+$"
    },
    "score": {
      "type": "number",
      "minimum": 0,
      "maximum": 1
    },
    "status": {
      "type": "string",
      "minLength": 1
    },
    "latency_ms": {
      "type": "number",
      "minimum": 0
    },
    "error_rate": {
      "type": "number",
      "minimum": 0,
      "maximum": 1
    }
  },
  "required": [
    "workspace_id",
    "tool_key",
    "score",
    "status",
    "latency_ms",
    "error_rate"
  ]
}
