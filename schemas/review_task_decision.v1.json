{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "ReviewTaskDecisionV1",
  "type": "object",
  "additionalProperties": false,
  "required": ["decision", "reason"],
  "properties": {
    "decision": {
      "type": "string",
      "enum": ["approved", "rejected"]
    },
    "reason": { "type": "string", "minLength": 1 }
  }
}
