{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "lesson_id": {
      "type": "string",
      "minLength": 1
    },
    "workspace_id": {
      "type": "string",
      "minLength": 1
    },
    "title": {
      "type": "string",
      "minLength": 1,
      "maxLength": 200
    },
    "summary": {
      "type": "string",
      "maxLength": 2000
    },
    "status": {
      "type": "string",
      "minLength": 1
    }
  },
  "required": [
    "lesson_id",
    "workspace_id",
    "title",
    "summary",
    "status"
  ]
}
