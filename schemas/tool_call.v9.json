{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "tool_key": {
      "type": "string",
      "pattern": "^[a-z0-9_]+\\.[a-z0-9_]+$"
    },
    "idempotency_key": {
      "type": "string",
      "minLength": 16,
      "maxLength": 128
    },
    "arguments": {
      "type": "object"
    },
    "requested_risk": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "level": {
          "type": "string"
        },
        "reversible": {
          "type": "boolean"
        }
      },
      "required": [
        "level",
        "reversible"
      ]
    },
    "workspace_id": {
      "type": "string",
      "pattern": "^[0-9a-f]{8}-[0-9a-f]{4}-7[0-9a-f]{3}-[89ab][0-9a-f]{3}-[0-9a-f]{12}$"
    },
    "ingress_turn_id": {
      "type": "string",
      "pattern": "^[0-9a-f]{8}-[0-9a-f]{4}-7[0-9a-f]{3}-[89ab][0-9a-f]{3}-[0-9a-f]{12}$"
    }
  },
  "required": [
    "tool_key",
    "idempotency_key",
    "arguments",
    "requested_risk",
    "workspace_id",
    "ingress_turn_id"
  ]
}
