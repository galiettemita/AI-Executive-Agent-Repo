{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "max_allowed_risk_level": {
      "type": "string",
      "minLength": 1
    },
    "require_operator_review_at_or_above": {
      "type": "string",
      "minLength": 1
    },
    "allowed_server_ids": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "denied_server_ids": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "oauth_owner_approval_required": {
      "type": "boolean"
    },
    "mcp_deploy_owner_approval_required": {
      "type": "boolean"
    }
  },
  "required": [
    "max_allowed_risk_level",
    "require_operator_review_at_or_above",
    "allowed_server_ids",
    "denied_server_ids",
    "oauth_owner_approval_required",
    "mcp_deploy_owner_approval_required"
  ]
}
