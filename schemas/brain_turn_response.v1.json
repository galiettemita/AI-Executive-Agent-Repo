{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "BrainTurnResponseV1",
  "type": "object",
  "additionalProperties": false,
  "required": ["turn_id", "state", "response_text"],
  "properties": {
    "turn_id": { "type": "string", "format": "uuid" },
    "state": { "type": "string" },
    "response_text": { "type": "string" },
    "plan_tier": { "type": "string" },
    "events": {
      "type": "array",
      "items": { "type": "string" }
    }
  }
}
