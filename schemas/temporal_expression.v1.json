{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "expression": {
      "type": "string",
      "minLength": 1,
      "maxLength": 500
    },
    "timezone": {
      "type": "string",
      "minLength": 1
    },
    "reference_ts": {
      "type": "string",
      "format": "date-time"
    }
  },
  "required": [
    "expression",
    "timezone",
    "reference_ts"
  ]
}
