{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "framework": {
      "type": "string",
      "minLength": 1
    },
    "evidence_id": {
      "type": "string",
      "minLength": 1
    },
    "artifact_hash": {
      "type": "string",
      "pattern": "^[a-f0-9]{64}$"
    },
    "artifact_uri": {
      "type": "string",
      "minLength": 1
    },
    "collected_at": {
      "type": "string",
      "format": "date-time"
    }
  },
  "required": [
    "framework",
    "evidence_id",
    "artifact_hash",
    "artifact_uri",
    "collected_at"
  ]
}
