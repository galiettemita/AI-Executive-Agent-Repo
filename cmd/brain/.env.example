# ═══════════════════════════════════════════════════════════════════════════════
# BREVIO BRAIN SERVICE — ENVIRONMENT CONFIGURATION
# Copy this file to .env and fill in real values before starting locally.
# Vars marked REQUIRED must be set; OPTIONAL vars have stated defaults.
# ═══════════════════════════════════════════════════════════════════════════════

# ─── Core Infrastructure (REQUIRED) ───────────────────────────────────────────
DATABASE_URL=postgres://user:password@localhost:5432/brevio
REDIS_URL=redis://localhost:6379
TEMPORAL_HOST=localhost:7233

# ─── Service Config ────────────────────────────────────────────────────────────
SERVICE_VERSION=v1.0.0
ENVIRONMENT=development
LOG_LEVEL=info

# ─── LLM (REQUIRED for reasoning, task extraction, sentiment) ──────────────────
ANTHROPIC_API_KEY=sk-ant-...

# ─── OpenAI (OPTIONAL — TTS skill + embeddings) ───────────────────────────────
OPENAI_API_KEY=sk-...

# ─── Deepgram Nova-3 STT (REQUIRED for voice features) ────────────────────────
# Used by: DeepgramProvider (REST, PROMPT 04) + DeepgramWSClient (WS, PROMPT 13)
DEEPGRAM_API_KEY=...

# ─── Cartesia Sonic-3 TTS (REQUIRED for streaming voice) ──────────────────────
# Used by: CartesiaTTSProvider (PROMPT 05)
CARTESIA_API_KEY=...

# ─── Gemini (REQUIRED for gemini-stt skill + vision pipeline) ─────────────────
# Used by: gemini-stt skill (PROMPT 01) + GeminiVisionProvider (PROMPT 10)
GEMINI_API_KEY=...

# ─── LiveKit Real-Time Voice (REQUIRED for LiveKit sessions) ───────────────────
# Used by: InitVoiceSessionActivity (PROMPT 03), LiveKitTokenSigner (PROMPT 11)
LIVEKIT_API_KEY=...
LIVEKIT_API_SECRET=...
LIVEKIT_URL=wss://your-project.livekit.cloud

# ─── AWS S3 Audio Storage (REQUIRED when voice features are enabled) ───────────
# Used by: S3AudioUploader in CartesiaTTSProvider (PROMPT 05)
AWS_ACCESS_KEY_ID=...
AWS_SECRET_ACCESS_KEY=...
AWS_REGION=us-east-1

# Cartesia TTS audio storage (PROMPT 05)
CARTESIA_TTS_S3_BUCKET=brevio-tts-audio
CARTESIA_TTS_S3_REGION=us-east-1
CARTESIA_TTS_S3_PREFIX=tts/cartesia

# OpenAI TTS audio storage (PROMPT 02)
OPENAI_TTS_S3_BUCKET=brevio-tts-audio
OPENAI_TTS_S3_REGION=us-east-1
OPENAI_TTS_S3_PREFIX=tts/openai
OPENAI_TTS_URL_EXPIRY_SEC=3600
